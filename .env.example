# =============================================================================
# Variáveis de ambiente — NUNCA commitar o arquivo .env real
# Copie este arquivo para `.env` e preencha com valores reais:
#   cp .env.example .env
# =============================================================================

# --- Banco de dados ---------------------------------------------------------
# OBRIGATÓRIO em produção. Para dev local, pode usar valores quaisquer.
POSTGRES_USER=hackathon
POSTGRES_PASSWORD=troque-essa-senha-em-producao
POSTGRES_DB=voluntariado_db

# DATABASE_URL é montada automaticamente a partir das variáveis acima
# pelo docker-compose. Só descomente abaixo se rodar a API fora do Docker.
# DATABASE_URL=postgresql://hackathon:senha@localhost:5433/voluntariado_db

# --- pgAdmin (apenas dev local — docker-compose.dev.yml) -------------------
PGADMIN_DEFAULT_EMAIL=admin@local.test
PGADMIN_DEFAULT_PASSWORD=troque-essa-senha-tambem

# --- Provedor de IA ---------------------------------------------------------
# Valores: fallback (default, keyword-based) | watsonx
IA_PROVIDER=fallback

# --- watsonx.ai (preencher quando IA_PROVIDER=watsonx) ---------------------
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct
WATSONX_URL=https://us-south.ml.cloud.ibm.com
